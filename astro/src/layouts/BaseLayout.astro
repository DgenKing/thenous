---
import '@fontsource-variable/fraunces';
import '@fontsource-variable/inter';
import '../styles/global.css';
import { partsNav, progressData } from '../lib/site';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
}
const { title, description, canonicalPath = '/', ogImage } = Astro.props;
const parts = await partsNav();
const progress = await progressData();
const canonical = new URL(canonicalPath, Astro.site);
const socialTitle = title === 'The Nous' ? 'The Nous' : `${title} - The Nous`;
const imageUrl = ogImage ? new URL(ogImage, Astro.site).href : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- deploy-check: 2026-07-17a -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{socialTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    <meta property="og:site_name" content="The Nous" />
    <meta name="twitter:card" content={imageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={description} />
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <a class="skip-to-content" href="#main-content">Skip to content</a>
    <header class="site-header">
      <div class="nav-shell">
        <a class="navbar-brand" href="/"><img src="/images/the-nous-logo.webp" alt="The Nous Logo" height="30" />The Nous</a>
        <button class="nav-toggle" type="button" aria-controls="site-nav" aria-expanded="false" aria-label="Toggle navigation">☰</button>
        <nav class="site-nav" id="site-nav" aria-label="Primary navigation">
          <ul>
            <li><a href="/">Home</a></li>
            <li class="dropdown">
              <button class="dropdown-trigger" type="button" aria-haspopup="true">Theory</button>
              <ul class="dropdown-menu">
                {parts.map((part) => <li><a href={part.href}>{part.title}</a></li>)}
              </ul>
            </li>
          </ul>
        </nav>
      </div>
    </header>
    <main class="main-content" id="main-content"><slot /></main>
    <footer class="footer"><div class="footer-content"><p>© 2026 The Nous. All rights reserved.</p><p><a id="contact-link" class="contact-link" href="#" rel="nofollow">Contact</a></p><p class="text-muted">Exploring consciousness, reality, and awakening.</p></div></footer>
    <script type="application/json" id="progress-data" set:html={JSON.stringify(progress)}></script>
    <script is:inline>
      const header = document.querySelector('.site-header');
      const toggle = document.querySelector('.nav-toggle');
      toggle?.addEventListener('click', () => {
        const open = header?.classList.toggle('nav-open') ?? false;
        toggle.setAttribute('aria-expanded', String(open));
      });

      // Fade body images in as they scroll into view
      const imgs = document.querySelectorAll('.content-wrap img');
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      imgs.forEach((img) => { img.classList.add('reveal'); io.observe(img); });

      // Gently reveal each section — fires early (section still below the fold)
      // so text is fully in place by the time it reaches the reading zone
      const sections = document.querySelectorAll('.content-wrap .doc-section');
      const secIo = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('is-visible'); secIo.unobserve(e.target); }
        });
      }, { threshold: 0, rootMargin: '0px 0px 12% 0px' });
      sections.forEach((s) => { s.classList.add('reveal-section'); secIo.observe(s); });

      // --- Reading progress (localStorage; per-device, no backend) ---
      (function () {
        const KEY = 'thenous:read';
        let read;
        try { read = new Set(JSON.parse(localStorage.getItem(KEY) || '[]')); } catch (e) { read = new Set(); }
        const save = () => { try { localStorage.setItem(KEY, JSON.stringify([...read])); } catch (e) {} };
        const norm = (p) => (p.endsWith('/') ? p : p + '/');
        let data = [];
        try { data = JSON.parse(document.getElementById('progress-data').textContent); } catch (e) {}
        const byPart = new Map();
        data.forEach((e) => byPart.set(norm(e.partHref), e));
        const tick = () => {
          const s = document.createElement('span');
          s.className = 'read-tick'; s.textContent = '✓'; s.setAttribute('aria-label', 'read');
          return s;
        };

        function render() {
          // Menu: tick a part only when every page in it is read
          document.querySelectorAll('.dropdown-menu a').forEach((a) => {
            const e = byPart.get(norm(new URL(a.href).pathname));
            a.querySelector('.read-tick')?.remove();
            if (e && e.chapters.every((c) => read.has(norm(c)))) a.appendChild(tick());
          });
          // Cards: home cards link to a part (show x/y + tick), index cards link to a chapter (tick)
          document.querySelectorAll('.chapter-card').forEach((card) => {
            const a = card.querySelector('a'); if (!a) return;
            const path = norm(new URL(a.href).pathname);
            card.querySelector('.read-tick')?.remove();
            card.querySelector('.progress-count')?.remove();
            const h = card.querySelector('h3');
            const partEntry = byPart.get(path);
            if (partEntry) {
              const done = partEntry.chapters.filter((c) => read.has(norm(c))).length;
              const total = partEntry.chapters.length;
              const s = document.createElement('span');
              s.className = 'progress-count'; s.textContent = done + '/' + total;
              h && h.appendChild(s);
              if (done === total) { card.classList.add('is-read'); h && h.appendChild(tick()); }
            } else if (read.has(path)) {
              card.classList.add('is-read'); h && h.appendChild(tick());
            }
          });
        }

        // Mark the current chapter page read once the bottom nav scrolls into view
        const nav = document.querySelector('.page-navigation');
        const here = norm(location.pathname);
        const isChapter = data.some((e) => e.chapters.some((c) => norm(c) === here));
        if (nav && isChapter && !read.has(here)) {
          const obs = new IntersectionObserver((ents) => {
            ents.forEach((en) => { if (en.isIntersecting) { read.add(here); save(); obs.disconnect(); render(); } });
          }, { threshold: 0 });
          obs.observe(nav);
        }
        render();
      })();

      // Spam-safe contact link: the address is assembled from encoded parts only
      // on click, so it never appears in the HTML/DOM for scrapers to harvest.
      (function () {
        const link = document.getElementById('contact-link');
        if (!link) return;
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const u = atob('ZGdlbmtpbmc=');
          const d = atob('bWFpbC5jb20=');
          window.location.href = 'mailto:' + u + '@' + d + '?subject=' + encodeURIComponent('The Nous');
        });
      })();
    </script>
  </body>
</html>
