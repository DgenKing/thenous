---
import '../styles/global.css';

interface PartLink { title: string; href: string; }
interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
  parts?: PartLink[];
}
const { title, description, canonicalPath = '/', ogImage, parts = [] } = Astro.props;
const canonical = new URL(canonicalPath, Astro.site);
const socialTitle = `${title} - The Pattern`;
const imageUrl = ogImage ? new URL(ogImage, Astro.site).href : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{socialTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    <meta property="og:site_name" content="The Pattern" />
    <meta name="twitter:card" content={imageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={description} />
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <a class="skip-to-content" href="#main-content">Skip to content</a>
    <header class="site-header">
      <div class="nav-shell">
        <a class="navbar-brand" href="/"><img src="/images/the-pattern-logo.webp" alt="The Pattern Logo" height="30" />The Pattern</a>
        <button class="nav-toggle" type="button" aria-controls="site-nav" aria-expanded="false" aria-label="Toggle navigation">☰</button>
        <nav class="site-nav" id="site-nav" aria-label="Primary navigation">
          <ul>
            <li><a href="/">Home</a></li>
            <li class="dropdown">
              <button class="dropdown-trigger" type="button" aria-haspopup="true">Theory</button>
              <ul class="dropdown-menu">
                {parts.map((part) => <li><a href={part.href}>{part.title}</a></li>)}
              </ul>
            </li>
          </ul>
        </nav>
      </div>
    </header>
    <main class="main-content" id="main-content"><slot /></main>
    <footer class="footer"><div class="footer-content"><p>© 2025 The Pattern. All rights reserved.</p><p class="text-muted">Exploring consciousness, reality, and awakening.</p></div></footer>
    <script is:inline>
      const header = document.querySelector('.site-header');
      const toggle = document.querySelector('.nav-toggle');
      toggle?.addEventListener('click', () => {
        const open = header?.classList.toggle('nav-open') ?? false;
        toggle.setAttribute('aria-expanded', String(open));
      });
    </script>
  </body>
</html>
