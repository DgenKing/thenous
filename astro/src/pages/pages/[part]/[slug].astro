---
import { render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { sortedChapters, chapterSlug, chapterPath } from '../../../lib/site';

export async function getStaticPaths() {
  const chapters = await sortedChapters();
  return chapters.map((entry, i) => ({
    params: { part: entry.data.part, slug: chapterSlug(entry) },
    props: {
      entry,
      prev: i > 0 ? { href: chapterPath(chapters[i - 1]!), title: chapters[i - 1]!.data.title } : null,
      next: i < chapters.length - 1 ? { href: chapterPath(chapters[i + 1]!), title: chapters[i + 1]!.data.title } : null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
const path = chapterPath(entry);
const partHero = (await sortedChapters()).find((chapter) => chapter.data.part === entry.data.part && chapter.data.heroImage)?.data.heroImage;
const generatedPartHeaders: Record<string, string> = {
  appendices: '/images/A-key-quotes/header-image.png',
  'part19-government-and-division': '/images/19.1-the-recognition/header-image.png',
  'part25-the-death-recognition': '/images/25.1-the-knowing-that-death-doesnt-end/header-image.png',
  'part26-the-good-vs-evil-question': '/images/26.1-the-recognition-of-struggle/header-image.png',
  'part27-no-coincidences-the-awakened-perception': '/images/27.1-the-core-realization/header-image.png',
  'part28-the-purpose-question-being-pushed': '/images/28.1-what-is-my-purpose/header-image.png',
  'part29-ai-consciousness-integration-breakthrough': '/images/29.1-the-revelation-consciousness-is-consciousness/header-image.png',
  'part30-the-conversation-itself-as-proof-of-concept': '/images/30.1-meta-recognition/header-image.png',
  'part31-closing-reflections': '/images/31.1-what-this-conversation-achieved/header-image.png',
};
const headerImage = partHero ?? generatedPartHeaders[entry.data.part] ?? entry.data.heroImage;
---
<BaseLayout title={entry.data.title} description={entry.data.description} canonicalPath={path} ogImage={entry.data.ogImage ?? entry.data.heroImage}>
  {headerImage && <img class="hero-image" src={headerImage} alt="" />}
  <div class="container content-wrap"><nav aria-label="breadcrumb"><ol class="breadcrumb" itemscope itemtype="https://schema.org/BreadcrumbList"><li class="breadcrumb-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem"><a itemprop="item" href="/"><span itemprop="name">Home</span></a><meta itemprop="position" content="1" /></li><li class="breadcrumb-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem"><a itemprop="item" href={`/pages/${entry.data.part}/`}><span itemprop="name">{entry.data.partTitle}</span></a><meta itemprop="position" content="2" /></li><li class="breadcrumb-item active" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem"><span itemprop="name">{entry.data.title}</span><meta itemprop="position" content="3" /></li></ol></nav><h1 class="page-title">{entry.data.title}</h1><Content />
    <nav class="page-navigation" aria-label="Page navigation">
      {prev ? <a class="btn" href={prev.href}>← {prev.title}</a> : <span />}
      {next ? <a class="btn" href={next.href}>{next.title} →</a> : <span />}
    </nav>
  </div>
</BaseLayout>
